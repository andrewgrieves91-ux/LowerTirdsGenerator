{
  "name": "lower-thirds-generator-offline",
  "version": "2.0.0",
  "description": "Lower Thirds Generator — offline desktop app",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node server/index.js",
    "start:legacy": "node dist/index.js",
    "electron": "unset ELECTRON_RUN_AS_NODE && electron .",
    "build:mac": "electron-builder --mac",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4.21.2",
    "zod": "^4.3.6"
  },
  "author": "Lower Thirds Generator",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.2"
  },
  "build": {
    "appId": "com.lowerthirds.generator",
    "productName": "Lower Thirds Generator",
    "mac": {
      "category": "public.app-category.video",
      "icon": "electron/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "dist/public/**/*",
      "!node_modules/vitest/**",
      "!node_modules/supertest/**",
      "!tests/**",
      "!client/**"
    ],
    "asar": true,
    "asarUnpack": [
      "dist/public/assets/ffmpeg/**"
    ]
  }
}
